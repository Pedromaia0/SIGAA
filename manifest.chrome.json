{
  "manifest_version": 3,
  "name": "SIGAA+",
  "version": "1.2.0",
  "description": "Adiciona funcionalidades para o SIGAA",

  "icons": {
    "128": "assets/icons/icon128.png",
    "750": "assets/icons/icon.png"
  },

  "action": {
    "default_popup": "src/popup/popup.html"
  },

  "permissions": ["storage"],

  "background": {
    "service_worker": "src/background/background.js"
  },

  "host_permissions": [
    "https://sigaa.ufrn.br/*",
    "https://arquivos.info.ufrn.br/*"
  ],
  "content_scripts": [
    {
      "js": [
        "src/utils/constants.js",
        "src/utils/dateUtils.js",
        "src/api/browserApi.js",
        "src/content/timeTable.js",
        "src/content/hideGrades.js"
      ],
      "matches": ["https://sigaa.ufrn.br/sigaa/portais/discente/discente.jsf"],
      "run_at": "document_end"
    },
    {
      "matches": ["https://sigaa.ufrn.br/sigaa/*"],
      "js": [
        "src/api/browserApi.js",
        "src/content/preventDownload.js",
        "src/content/patchJsfLinks.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://sigaa.ufrn.br/sigaa/*"],
      "js": ["src/api/browserApi.js", "src/content/themeInjection.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["assets/*", "styles/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
